# Skopiuj do .streamlit/secrets.toml (lokalnie) LUB wklej w Streamlit Cloud → App settings → Secrets.
# Gdy te dwa klucze są ustawione, apka pisze do Turso. Gdy nie — używa lokalnego pliku leki.db.

TURSO_DATABASE_URL = "libsql://nazwa-bazy-xxxxx.turso.io"
TURSO_AUTH_TOKEN = "wklej-tutaj-token-z-turso"

# Gdy apka jest publiczna, ustaw hasło. Gdy pusto/brak — apka bez bramki (dla trybu lokalnego).
APP_PASSWORD = "wymyslone-dlugie-haslo"
